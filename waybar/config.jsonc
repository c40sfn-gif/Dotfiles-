{
    "layer": "top",
    "position": "top",
    "height": 32,
    "margin-top": 5,
    "margin-left": 10,
    "margin-right": 10,
    "spacing": 4,
    "modules-left": ["custom/launcher", "sway/workspaces", "sway/mode", "sway/window"],
    "modules-center": ["clock"],
    "modules-right": ["custom/keychron", "pulseaudio", "battery", "cpu", "memory", "custom/mifibra", "network", "custom/power"],

    "custom/launcher": {
        "format": "🤖",
        "on-click": "rofi -show drun -theme ~/.config/rofi/cyberpunk.rasi",
        "tooltip": false
    },
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}",
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": []
        }
    },
    "clock": {
        "format": "{:%a, %d %b %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "custom/keychron": {
        "format": "Fr4ncim4r🌌",
        "tooltip": false
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "",
        "format-icons": {
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-icons": ["", "", "", "", ""]
    },
    "cpu": {
        "format": "💽{usage}%",
        "tooltip": true,
        "interval": 2
    },
    "memory": {
        "format": "🧠{used:0.1f}G"
    },
    "custom/mifibra": {
        "format": "SkyNet👁️",
        "tooltip": false
    },
    "network": {
        "format-wifi": " {signalStrength}%",
        "format-ethernet": "👀",
        "format-disconnected": "⚠",
        "on-click": "nm-connection-editor"
    },
    "custom/power": {
        "format": "☣️",
        "on-click": "swaynag -t warning -m 'Power Menu' -b 'Shutdown' 'systemctl poweroff' -b 'Reboot' 'systemctl reboot' -b 'Logout' 'swaymsg exit'",
        "tooltip": false
    }
}
