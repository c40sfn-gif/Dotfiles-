{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["clock"],
    "modules-right": ["pulseaudio", "network", "cpu", "memory", "battery", "tray", "custom/power"],

    "sway/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "ΎΚσ",
            "2": "ΎΕκ",
            "3": "ΎΕι",
            "default": "ΎΕΣ"
        }
    },
    "clock": {
        "format": "ΎΑΩ  {:%H:%M}",
        "format-alt": "ΎΒ│  {:%d/%m/%Y}"
    },
    "cpu": { "format": "ΎΜδ  {usage}%", "interval": 5 },
    "memory": { "format": "ΎΦ╕  {}%" },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "Ύγσ",
        "format-icons": { "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"] }
    },

"memory": {
    "format": "RAM {percentage}%",
    "tooltip": false
}, 

"custom/power": {
    "format": "έΠ╗ ",
    "on-click": "swaynag -t warning -m 'O que deseja fazer?' -b 'Desligar' 'shutdown now' -b 'Reiniciar' 'reboot' -b 'Suspender' 'systemctl suspend'",
    "tooltip": false
},

"network": {
    "interval": 2,
    "format-wifi": "ΎΘτ  {essid} ({signalStrength}%)",
    "format-ethernet": "≤░ΙΑ  {ifname}",
    "format-linked": "≤░ΙΑ  {ifname} (No IP)",
    "format-disconnected": "≤░Γφ  Disconnected",
    "format-alt": "≤░ΧΤ {bandwidthUpBytes} ≤░Θγ {bandwidthDownBytes}",
    "tooltip-format": "{ifname} via {gwaddr} ΎηΨ"
  }
}

